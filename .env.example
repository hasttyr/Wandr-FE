# ─── wandr Environment Variables ─────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores

# URL de tu microservicio de IA (FastAPI, Express, etc.)
VITE_AI_SERVICE_URL=http://localhost:8000/api/ai

# O conecta directamente a Anthropic (no recomendado en producción — expone la API key)
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# URL de tu API backend para autenticación y persistencia
# VITE_API_URL=http://localhost:3000/api
